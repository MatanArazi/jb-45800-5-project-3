# Database Configuration
# Copy this file to .env and fill in your actual values

# MySQL Root Password - used for initial setup
DB_ROOT_PASSWORD=rootpassword

# Database Name - will be created automatically
DB_NAME=vacation_db

# Database User - created automatically
DB_USER=vacation_user

# Database User Password
DB_PASSWORD=userpassword

# Database Port - exposed to localhost
DB_PORT=3306

# Node.js Environment
NODE_ENV=development

# API Server Port (when you create it)
API_PORT=5000

# Frontend Port (when you create it)
FRONTEND_PORT=3000

# JWT Secret (add later when you add authentication)
JWT_SECRET=your_jwt_secret_key_here

# Application Name
APP_NAME=Vacation Website
