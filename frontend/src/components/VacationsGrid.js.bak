import React from 'react';
import VacationCard from './VacationCard';

export default function VacationsGrid({ vacations, userLikes, toggleLike, handleBooking, formatPrice }) {
  return (
    <section className="vacations-grid">
      {vacations.map(v => (
        <VacationCard
          key={v.vacation_id}
          vacation={v}
          userLikes={userLikes}
          toggleLike={toggleLike}
          handleBooking={handleBooking}
          formatPrice={formatPrice}
        />
      ))}
    </section>
  );
}
